# PostgreSQL
POSTGRES_DB=assignia_db
POSTGRES_USER=assignia_user
POSTGRES_PASSWORD=assignia_password
SQL_HOST=db
SQL_PORT=5432
DATABASE=postgres

# Django
SECRET_KEY=сгенерирированный-ключ
DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost,https://127.0.0.1

# Production
SECURE_HSTS = False

# Email (разработка: console, продакшен: smtp)
EMAIL_BACKEND_TYPE=console
# SMTP (при продакшене)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@example.com

# Домен
BASE_URL=http://localhost:8000